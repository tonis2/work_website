# Copy to .env on the server and fill in. Loaded by the systemd unit
# (EnvironmentFile), not by the app itself.
PORT=8721

# SMTP relay credentials (Brevo/Mailjet free tier, or your mailbox provider's
# SMTP). Sending directly from the VPS without a relay usually lands in spam.
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where form submissions are delivered, and the envelope sender (must be a
# sender address verified with your SMTP relay).
MAIL_TO=hello@internus.dev
MAIL_FROM=hello@internus.dev
